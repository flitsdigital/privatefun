{%- comment -%}
  Gratis-verzending voortgangsbalk voor de winkelwagen (drawer + cart-pagina).
  Drempel instelbaar via Thema-instellingen > Winkelwagen > "Gratis verzending vanaf" (0 = uit).
{%- endcomment -%}
{%- liquid
  assign threshold = settings.cart_free_shipping_threshold | default: 0 | times: 100
-%}
{%- if threshold > 0 and cart.item_count > 0 -%}
  {%- assign remaining = threshold | minus: cart.total_price -%}
  {%- assign pct = cart.total_price | times: 100.0 | divided_by: threshold -%}
  {%- if pct > 100 -%}{%- assign pct = 100 -%}{%- endif -%}
  <div class="cart-fs">
    <p class="cart-fs__label">
      {%- if remaining > 0 -%}
        Nog <strong>{{ remaining | money }}</strong> tot <span class="cart-fs__free">gratis verzending</span>
      {%- else -%}
        <span class="cart-fs__free">Je hebt gratis verzending</span>
      {%- endif -%}
    </p>
    <div class="cart-fs__track"><span class="cart-fs__fill" style="width: {{ pct }}%;"></span></div>
  </div>
{%- endif -%}
{% stylesheet %}
  .cart-fs { padding: 16px var(--cart-drawer-padding, 20px); border-bottom: 1px solid rgb(var(--color-foreground-rgb) / .12); }
  .cart-fs__label { margin: 0 0 10px; font-size: 12px; letter-spacing: .04em; text-align: center; color: rgb(var(--color-foreground-rgb) / .82); }
  .cart-fs__label strong { color: rgb(var(--color-foreground-rgb)); font-weight: 600; }
  .cart-fs__free { color: #c9a063; text-transform: uppercase; letter-spacing: .1em; font-size: 11px; font-weight: 600; }
  .cart-fs__track { height: 3px; background: rgb(var(--color-foreground-rgb) / .14); overflow: hidden; }
  .cart-fs__fill { display: block; height: 100%; background: #c9a063; transition: width .5s cubic-bezier(.4,0,.2,1); }
{% endstylesheet %}
