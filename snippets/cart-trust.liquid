{%- comment -%} Trust-regels onder de winkelwagen-samenvatting (drawer + cart-pagina) {%- endcomment -%}
<ul class="cart-trust">
  <li>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M4 8h16v12H4z"/><path d="M4 8l2-4h12l2 4M12 8v12"/></svg>
    Discreet verpakt &amp; verzonden — geen logo op de doos
  </li>
  <li>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="5" y="10" width="14" height="10" rx="1"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
    Veilig betalen — iDEAL, Klarna, PayPal &amp; meer
  </li>
  <li>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M4 10h11a5 5 0 0 1 0 10H9"/><path d="m8 6-4 4 4 4"/></svg>
    14 dagen bedenktijd op ongeopende producten
  </li>
</ul>
{% stylesheet %}
  .cart-trust { list-style: none; margin: 0; padding: 14px 0 0; display: grid; gap: 8px; width: 100%; }
  .cart-trust li { display: flex; align-items: center; gap: 9px; font-size: 11px; letter-spacing: .03em; color: rgb(var(--color-foreground-rgb) / .72); }
  .cart-trust svg { width: 14px; height: 14px; color: #CE9D27; flex: none; }
{% endstylesheet %}
