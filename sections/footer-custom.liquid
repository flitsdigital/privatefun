{%- liquid
  assign uid = section.id
  assign s = section.settings
-%}

<style>
  {{ s.font_display | font_face: font_display: 'swap' }}
  {{ s.font_body | font_face: font_display: 'swap' }}

  .ft-{{ uid }} {
    --ft-accent: {{ s.color_accent }};
    --ft-text: {{ s.color_text }};
    --ft-line: color-mix(in srgb, {{ s.color_text }} 14%, transparent);

    background: {{ s.color_bg }};
    color: var(--ft-text);
    font-family: {{ s.font_body.family }}, {{ s.font_body.fallback_families }};
  }
  .ft-{{ uid }} *, .ft-{{ uid }} *::before, .ft-{{ uid }} *::after { box-sizing: border-box; }
  .ft-{{ uid }}__inner { max-width: 1240px; margin: 0 auto; padding: 0 24px; }

  /* ---------- beloftebalk ---------- */
  .ft-{{ uid }}__promises {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    padding: 28px 0;
    margin: 0;
    list-style: none;
    border-bottom: 1px solid var(--ft-line);
  }
  .ft-{{ uid }}__promise {
    display: flex;
    align-items: center;
    gap: 11px;
    font-size: 13px;
    line-height: 1.4;
  }
  .ft-{{ uid }}__promise svg { width: 19px; height: 19px; flex: none; color: var(--ft-accent); }

  /* ---------- kolommen ---------- */
  .ft-{{ uid }}__grid {
    display: grid;
    grid-template-columns: 1.4fr repeat({{ section.blocks.size | at_least: 1 | at_most: 3 }}, minmax(0, 1fr));
    gap: 48px;
    padding: 56px 0;
  }

  .ft-{{ uid }}__logo {
    display: inline-block;
    margin-bottom: 16px;
    font-family: {{ s.font_display.family }}, {{ s.font_display.fallback_families }};
    font-size: 20px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ft-accent);
    text-decoration: none;
    line-height: 0;
  }
  .ft-{{ uid }}__logo img { display: block; height: {{ s.logo_height }}px; width: auto; }
  .ft-{{ uid }}__about {
    margin: 0;
    max-width: 30ch;
    font-family: {{ s.font_display.family }}, {{ s.font_display.fallback_families }};
    font-size: 19px;
    line-height: 1.6;
    opacity: .9;
  }
  .ft-{{ uid }}__about em { font-style: italic; color: var(--ft-accent); }

  .ft-{{ uid }}__newsletter {
    margin-top: 28px;
    max-width: 370px;
    border: 1px solid var(--ft-line);
    background: color-mix(in srgb, var(--ft-text) 4%, transparent);
    padding: 20px 20px 16px;
  }
  .ft-{{ uid }}__nl-label {
    display: block;
    margin-bottom: 12px;
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ft-accent);
  }

  .ft-{{ uid }}__social { display: flex; gap: 16px; margin-top: 24px; }
  .ft-{{ uid }}__social a {
    display: inline-flex;
    color: var(--ft-text);
    opacity: .65;
    transition: opacity .18s ease, color .18s ease;
  }
  .ft-{{ uid }}__social a:hover { color: var(--ft-accent); opacity: 1; }
  .ft-{{ uid }}__social svg { width: 19px; height: 19px; }
  .ft-{{ uid }}__nl-row { display: flex; }
  .ft-{{ uid }}__nl-row input {
    flex: 1;
    min-width: 0;
    background: none;
    border: 1px solid var(--ft-line);
    border-right: 0;
    color: var(--ft-text);
    font: inherit;
    font-size: 14px;
    padding: 11px 13px;
  }
  .ft-{{ uid }}__nl-row input::placeholder { color: var(--ft-text); opacity: .4; }
  .ft-{{ uid }}__nl-row input:focus { outline: 0; border-color: var(--ft-accent); }
  .ft-{{ uid }}__nl-row button {
    flex: none;
    background: var(--ft-accent);
    color: {{ s.color_bg }};
    border: 0;
    font: inherit;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 0 18px;
    cursor: pointer;
    transition: opacity .18s ease;
  }
  .ft-{{ uid }}__nl-row button:hover { opacity: .88; }
  .ft-{{ uid }}__nl-note { margin: 8px 0 0; font-size: 11px; opacity: .5; }
  .ft-{{ uid }}__nl-done { margin: 9px 0 0; font-size: 13px; color: var(--ft-accent); }

  .ft-{{ uid }}__col-title {
    margin: 0 0 16px;
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ft-accent);
  }
  .ft-{{ uid }}__links { margin: 0; padding: 0; list-style: none; }
  .ft-{{ uid }}__links li + li { margin-top: 11px; }
  .ft-{{ uid }}__links a {
    font-size: 14px;
    color: var(--ft-text);
    opacity: .72;
    text-decoration: none;
    transition: opacity .18s ease, color .18s ease;
  }
  .ft-{{ uid }}__links a:hover { opacity: 1; color: var(--ft-accent); }

  /* ---------- onderbalk ---------- */
  .ft-{{ uid }}__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    padding: 24px 0;
    border-top: 1px solid var(--ft-line);
  }
  .ft-{{ uid }}__copy { margin: 0; font-size: 12px; opacity: .55; }
  .ft-{{ uid }}__copy a { color: inherit; text-decoration: none; border-bottom: 1px solid var(--ft-line); }
  .ft-{{ uid }}__pay { display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }
  .ft-{{ uid }}__pay svg { height: 22px; width: auto; }
  .ft-{{ uid }}__pay-label {
    margin: 0 8px 0 0;
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    font-weight: 600;
    opacity: .55;
  }

  .ft-{{ uid }}__brandmark { overflow: hidden; padding: 44px 0 0; }
  .ft-{{ uid }}__brandmark span {
    display: block;
    font-family: {{ s.font_display.family }}, {{ s.font_display.fallback_families }};
    font-size: clamp(64px, 10.5vw, 170px);
    line-height: .95;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-align: center;
    color: var(--ft-accent);
    opacity: .14;
    white-space: nowrap;
    user-select: none;
  }

  .ft-{{ uid }} a:focus-visible,
  .ft-{{ uid }} button:focus-visible,
  .ft-{{ uid }} input:focus-visible { outline: 2px solid var(--ft-accent); outline-offset: 3px; }

  /* ---------- mobiel ---------- */
  @media (max-width: 899px) {
    .ft-{{ uid }}__inner { padding: 0 20px; }
    .ft-{{ uid }}__promises { grid-template-columns: 1fr; gap: 14px; padding: 22px 0; }
    .ft-{{ uid }}__grid { grid-template-columns: 1fr; gap: 34px; padding: 36px 0; }
    .ft-{{ uid }}__newsletter { max-width: 100%; }
    .ft-{{ uid }}__bottom { justify-content: flex-start; }
  }
</style>

<footer class="ft-{{ uid }}">
  <div class="ft-{{ uid }}__inner">

    {%- if s.promise_1 != blank or s.promise_2 != blank or s.promise_3 != blank -%}
      <ul class="ft-{{ uid }}__promises">
        {%- if s.promise_1 != blank -%}
          <li class="ft-{{ uid }}__promise">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 8h16v12H4z"/><path d="M4 8l2-4h12l2 4M12 8v12"/></svg>
            <span>{{ s.promise_1 }}</span>
          </li>
        {%- endif -%}
        {%- if s.promise_2 != blank -%}
          <li class="ft-{{ uid }}__promise">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 16V6h11v10M14 9h4l3 3v4h-7"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
            <span>{{ s.promise_2 }}</span>
          </li>
        {%- endif -%}
        {%- if s.promise_3 != blank -%}
          <li class="ft-{{ uid }}__promise">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="10" width="14" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
            <span>{{ s.promise_3 }}</span>
          </li>
        {%- endif -%}
      </ul>
    {%- endif -%}

    <div class="ft-{{ uid }}__grid">

      <div class="ft-{{ uid }}__brand">
        <a class="ft-{{ uid }}__logo" href="{{ routes.root_url }}">
          {%- if s.logo != blank -%}
            {{ s.logo | image_url: width: 600 | image_tag: alt: shop.name, loading: 'lazy' }}
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </a>

        {%- if s.about != blank -%}
          <p class="ft-{{ uid }}__about">{{ s.about }}</p>
        {%- endif -%}

        {%- if s.show_newsletter -%}
          <div class="ft-{{ uid }}__newsletter">
            {%- form 'customer' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <label class="ft-{{ uid }}__nl-label" for="nl-{{ uid }}">{{ s.nl_label }}</label>
              <div class="ft-{{ uid }}__nl-row">
                <input id="nl-{{ uid }}" type="email" name="contact[email]" placeholder="{{ s.nl_placeholder }}" required>
                <button type="submit">{{ s.nl_button }}</button>
              </div>
              {%- if form.posted_successfully? -%}
                <p class="ft-{{ uid }}__nl-done">{{ s.nl_success }}</p>
              {%- elsif s.nl_note != blank -%}
                <p class="ft-{{ uid }}__nl-note">{{ s.nl_note }}</p>
              {%- endif -%}
            {%- endform -%}
          </div>
        {%- endif -%}

        {%- if s.instagram_url != blank or s.facebook_url != blank or s.tiktok_url != blank -%}
          <div class="ft-{{ uid }}__social">
            {%- if s.instagram_url != blank -%}
              <a href="{{ s.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"/></svg>
              </a>
            {%- endif -%}
            {%- if s.facebook_url != blank -%}
              <a href="{{ s.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 8h2.5V4.5H14A4.5 4.5 0 0 0 9.5 9v2H7v3.5h2.5v6h3.5v-6h2.5l.5-3.5h-3V9a1 1 0 0 1 1-1z"/></svg>
              </a>
            {%- endif -%}
            {%- if s.tiktok_url != blank -%}
              <a href="{{ s.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 4v9.5a4.5 4.5 0 1 1-4.5-4.5M15 4c.4 2.6 2 4.4 4.5 4.8"/></svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <p class="ft-{{ uid }}__col-title">{{ block.settings.title }}</p>
          {%- endif -%}
          <ul class="ft-{{ uid }}__links">
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}

    </div>

    {%- if s.big_text != blank -%}
      <div class="ft-{{ uid }}__brandmark" aria-hidden="true"><span>{{ s.big_text }}</span></div>
    {%- endif -%}

    <div class="ft-{{ uid }}__bottom">
      <p class="ft-{{ uid }}__copy">
        © {{ 'now' | date: '%Y' }} {{ s.brand_name | default: shop.name }}{% if s.kvk != blank %} · KvK {{ s.kvk }}{% endif %}{% if s.btw != blank %} · BTW {{ s.btw }}{% endif %}
      </p>

      {%- if s.show_payment -%}
        {%- liquid
          # ponytail: payment_list overschrijft de live gateways — dev-store heeft alleen PayPal (test)
          if s.payment_list != blank
            assign pay_types = s.payment_list | remove: ' ' | split: ','
          else
            assign pay_types = shop.enabled_payment_types
          endif
        -%}
        <div class="ft-{{ uid }}__pay">
          <span class="ft-{{ uid }}__pay-label">Veilig betalen</span>
          {%- for type in pay_types -%}
            {{ type | payment_type_svg_tag: class: 'ft-pay-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "footer-custom-section",
  "settings": [
    { "type": "header", "content": "Beloftes bovenaan" },
    { "type": "text", "id": "promise_1", "label": "Belofte 1", "default": "Neutrale verpakking, geen logo op de doos" },
    { "type": "text", "id": "promise_2", "label": "Belofte 2", "default": "Voor 22:00 besteld, morgen in huis" },
    { "type": "text", "id": "promise_3", "label": "Belofte 3", "default": "Discrete afschrijving op je rekening" },

    { "type": "header", "content": "Merk" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_height", "min": 20, "max": 140, "step": 4, "unit": "px", "label": "Logohoogte", "default": 96 },
    { "type": "text", "id": "about", "label": "Korte tekst", "default": "Zorgvuldig geselecteerd, discreet bezorgd. Voor hem, voor haar en voor samen." },

    { "type": "header", "content": "Nieuwsbrief" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Nieuwsbrief tonen", "default": true },
    { "type": "text", "id": "nl_label", "label": "Label", "default": "Nieuwe binnenkomers en aanbiedingen" },
    { "type": "text", "id": "nl_placeholder", "label": "Placeholder", "default": "je@email.nl" },
    { "type": "text", "id": "nl_button", "label": "Knop", "default": "Aanmelden" },
    { "type": "text", "id": "nl_note", "label": "Kleine tekst eronder", "default": "Geen spam. Uitschrijven kan altijd." },
    { "type": "text", "id": "nl_success", "label": "Bedanktekst", "default": "Gelukt. Je hoort van ons." },

    { "type": "header", "content": "Socials" },
    { "type": "url", "id": "instagram_url", "label": "Instagram" },
    { "type": "url", "id": "facebook_url", "label": "Facebook" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok" },

    { "type": "header", "content": "Onderbalk" },
    { "type": "text", "id": "big_text", "label": "Grote merknaam", "info": "Groot woordmerk boven de onderbalk. Leeg = verbergen.", "default": "Privatefun" },
    { "type": "text", "id": "brand_name", "label": "Naam in copyright", "info": "Leeg = winkelnaam uit Shopify." },
    { "type": "checkbox", "id": "show_payment", "label": "Betaalmethoden tonen", "default": true },
    { "type": "text", "id": "payment_list", "label": "Betaaliconen", "info": "Kommagescheiden. Leeg = automatisch (actieve betaalproviders).", "default": "ideal,visa,master,maestro,klarna,paypal,bancontact" },
    { "type": "text", "id": "kvk", "label": "KvK-nummer" },
    { "type": "text", "id": "btw", "label": "BTW-nummer" },

    { "type": "header", "content": "Typografie" },
    { "type": "font_picker", "id": "font_display", "label": "Logo", "default": "playfair_display_n4" },
    { "type": "font_picker", "id": "font_body", "label": "Tekst", "default": "assistant_n4" },

    { "type": "header", "content": "Kleuren" },
    { "type": "color", "id": "color_bg", "label": "Achtergrond", "default": "#0b0b0b" },
    { "type": "color", "id": "color_accent", "label": "Accent (goud)", "default": "#c9a063" },
    { "type": "color", "id": "color_text", "label": "Teksten", "default": "#e6e3dd" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Kolom",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "title", "label": "Kop", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}