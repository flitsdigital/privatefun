{%- liquid
  assign uid = section.id
  assign s = section.settings
  assign overlay = s.overlay_opacity | divided_by: 100.0
  assign heading_mobile = s.heading_size | times: 0.6 | round
  assign sub_mobile = s.sub_size | minus: 2
-%}

<style>
  {{ s.font_display | font_face: font_display: 'swap' }}
  {{ s.font_body | font_face: font_display: 'swap' }}

  .hc-{{ uid }} {
    --hc-accent: {{ s.color_accent }};
    --hc-text: {{ s.color_text }};
    --hc-cta-text: {{ s.color_cta_text }};

    position: relative;
    display: grid;
    place-items: center;
    min-height: {{ s.height }}px;
    padding: 48px 24px;
    overflow: hidden;
    background: {{ s.color_bg }};
    font-family: {{ s.font_body.family }}, {{ s.font_body.fallback_families }};
  }
  .hc-{{ uid }} *, .hc-{{ uid }} *::before, .hc-{{ uid }} *::after { box-sizing: border-box; }

  /* ---------- achtergrond ---------- */
  .hc-{{ uid }}__bg { position: absolute; inset: 0; z-index: 0; }
  .hc-{{ uid }}__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hc-{{ uid }}__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      /* leesbaarheids-pool recht achter de tekst */
      radial-gradient(ellipse 78% 68% at 50% 46%,
        rgb(0 0 0 / 0.68) 0%,
        rgb(0 0 0 / 0.34) 44%,
        rgb(0 0 0 / 0.08) 68%,
        transparent 82%),
      /* zachte vignet naar de randen */
      radial-gradient(135% 115% at 50% 30%, transparent 46%, {{ s.color_bg }} 124%),
      /* verticale diepte — midden niet meer volledig transparant */
      linear-gradient(to bottom,
        color-mix(in srgb, {{ s.color_bg }} 58%, transparent) 0%,
        color-mix(in srgb, {{ s.color_bg }} 30%, transparent) 42%,
        color-mix(in srgb, {{ s.color_bg }} 42%, transparent) 64%,
        color-mix(in srgb, {{ s.color_bg }} 86%, transparent) 100%);
    opacity: {{ overlay | plus: 0.26 }};
  }

  /* ---------- inhoud ---------- */
  .hc-{{ uid }}__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
    text-shadow: 0 1px 3px rgb(0 0 0 / 25%), 0 2px 30px rgb(0 0 0 / 35%);
  }
  .hc-{{ uid }}__eyebrow {
    margin: 0 0 14px;
    font-family: {{ s.font_body.family }}, {{ s.font_body.fallback_families }};
    font-size: 12px;
    font-weight: 500;
    letter-spacing: .24em;
    text-transform: uppercase;
    color: var(--hc-accent);
  }
  .hc-{{ uid }}__heading {
    margin: 0;
    font-family: {{ s.font_display.family }}, {{ s.font_display.fallback_families }};
    font-size: {{ s.heading_size }}px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    font-weight: 400;
    color: var(--hc-text);
  }
  .hc-{{ uid }}__heading em { font-style: italic; color: var(--hc-accent); }

  .hc-{{ uid }}__sub {
    margin: 18px auto 0;
    max-width: 46ch;
    font-size: {{ s.sub_size }}px;
    line-height: 1.65;
    color: var(--hc-text);
    opacity: .78;
  }
  .hc-{{ uid }}__sub p { margin: 0; }

  .hc-{{ uid }}__actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    margin-top: 28px;
    text-shadow: none;
  }
  .hc-{{ uid }}__cta {
    display: inline-block;
    background: var(--hc-accent);
    color: var(--hc-cta-text);
    padding: 14px 30px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform var(--animation-speed-medium) var(--animation-timing-hover), opacity var(--animation-speed-medium) var(--animation-timing-hover);
  }
  @media (hover: hover) and (pointer: fine) {
    .hc-{{ uid }}__cta:hover { transform: translateY(-2px); opacity: .92; }
  }
  .hc-{{ uid }}__link {
    display: inline-block;
    padding: 13px 28px;
    border: 1px solid color-mix(in srgb, var(--hc-text) 45%, transparent);
    color: var(--hc-text);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color var(--animation-speed-medium) var(--animation-timing-hover), transform var(--animation-speed-medium) var(--animation-timing-hover);
  }
  @media (hover: hover) and (pointer: fine) {
    .hc-{{ uid }}__link:hover { border-color: var(--hc-accent); transform: translateY(-2px); }
  }
  .hc-{{ uid }}__cta:focus-visible,
  .hc-{{ uid }}__link:focus-visible,
  .hc-{{ uid }}__score:focus-visible { outline: 2px solid var(--hc-accent); outline-offset: 4px; }

  .hc-{{ uid }}__scores {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px 24px;
    flex-wrap: wrap;
    margin: 22px 0 0;
  }
  .hc-{{ uid }}__score {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--hc-text);
    text-decoration: none;
    font-size: 13px;
    line-height: 1.3;
    transition: opacity var(--animation-speed-medium) var(--animation-timing-hover);
  }
  a.hc-{{ uid }}__score:hover { opacity: .75; }
  .hc-{{ uid }}__score-text { font-weight: 500; }
  .hc-{{ uid }}__score-text strong { font-weight: 700; }
  .hc-{{ uid }}__score-brand {
    flex: none;
    display: block;
    object-fit: contain;
  }
  .hc-{{ uid }}__score-brand--trustpilot { width: 18px; height: 18px; }
  .hc-{{ uid }}__score-brand--google { width: 18px; height: 18px; }

  .hc-{{ uid }}__usps {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px 26px;
    margin: 30px 0 0;
    padding: 0;
    list-style: none;
  }
  .hc-{{ uid }}__usp {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    color: var(--hc-text);
    opacity: .6;
  }
  .hc-{{ uid }}__usp svg { width: 15px; height: 15px; flex: none; }

  /* ---------- animatie ---------- */
  .hc-{{ uid }} [data-rise] {
    opacity: 0;
    transform: translateY(14px);
    animation: hc-rise-{{ uid }} var(--dur-media) var(--ease-media-zoom) forwards;
  }
  .hc-{{ uid }} [data-rise="1"] { animation-delay: .05s; }
  .hc-{{ uid }} [data-rise="2"] { animation-delay: .16s; }
  .hc-{{ uid }} [data-rise="3"] { animation-delay: .28s; animation-name: hc-rise-sub-{{ uid }}; }
  .hc-{{ uid }} [data-rise="4"] { animation-delay: .40s; }
  .hc-{{ uid }} [data-rise="5"] { animation-delay: .52s; animation-name: hc-rise-score-{{ uid }}; }
  .hc-{{ uid }} [data-rise="6"] { animation-delay: .64s; animation-name: hc-rise-usp-{{ uid }}; }
  @keyframes hc-rise-{{ uid }} { to { opacity: 1; transform: none; } }
  @keyframes hc-rise-sub-{{ uid }} { to { opacity: .78; transform: none; } }
  @keyframes hc-rise-score-{{ uid }} { to { opacity: .9; transform: none; } }
  @keyframes hc-rise-usp-{{ uid }} { to { opacity: .6; transform: none; } }

  /* ---------- mobiel ---------- */
  @media (max-width: 749px) {
    .hc-{{ uid }} { min-height: {{ s.height | times: 0.82 | round }}px; padding: 36px 20px; }
    .hc-{{ uid }}__heading { font-size: {{ heading_mobile }}px; }
    .hc-{{ uid }}__sub { font-size: {{ sub_mobile }}px; }
    .hc-{{ uid }}__scores { gap: 8px 18px; margin-top: 18px; }
    .hc-{{ uid }}__score { font-size: 12px; }
    .hc-{{ uid }}__cta, .hc-{{ uid }}__link { width: 100%; text-align: center; }
    .hc-{{ uid }}__usps { gap: 8px 18px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hc-{{ uid }} [data-rise] { animation: none !important; transform: none !important; opacity: 1 !important; }
    .hc-{{ uid }} [data-rise="3"] { opacity: .78 !important; }
    .hc-{{ uid }} [data-rise="5"] { opacity: .9 !important; }
    .hc-{{ uid }} [data-rise="6"] { opacity: .6 !important; }
  }
</style>

<div class="hc-{{ uid }}">

  <div class="hc-{{ uid }}__bg">
    {%- if s.image != blank -%}
      {{ s.image | image_url: width: 2400 | image_tag: alt: s.heading, loading: 'eager', sizes: '100vw' }}
    {%- endif -%}
  </div>

  <div class="hc-{{ uid }}__content">

    {%- if s.eyebrow != blank -%}
      <p class="hc-{{ uid }}__eyebrow" data-rise="1">{{ s.eyebrow }}</p>
    {%- endif -%}

    {%- if s.heading != blank -%}
      {%- liquid
        assign out = s.heading
        if s.emphasis != blank
          assign em_html = '<em>' | append: s.emphasis | append: '</em>'
          assign out = out | replace: s.emphasis, em_html
        endif
        assign out = out | newline_to_br
      -%}
      <h1 class="hc-{{ uid }}__heading" data-rise="2">{{ out }}</h1>
    {%- endif -%}

    {%- if s.subtext != blank -%}
      <div class="hc-{{ uid }}__sub" data-rise="3">{{ s.subtext }}</div>
    {%- endif -%}

    <div class="hc-{{ uid }}__actions" data-rise="4">
      {%- if s.cta_label != blank -%}
        <a class="hc-{{ uid }}__cta" href="{{ s.cta_link | default: '/collections/all' }}">{{ s.cta_label }}</a>
      {%- endif -%}
      {%- if s.link_label != blank -%}
        <a class="hc-{{ uid }}__link" href="{{ s.link_url | default: '/collections/all' }}">{{ s.link_label }}</a>
      {%- endif -%}
    </div>

    {%- if s.tp_score != blank or s.g_score != blank -%}
      <div class="hc-{{ uid }}__scores" data-rise="5">
        {%- if s.tp_score != blank -%}
          {%- capture tp_inner -%}
            <img class="hc-{{ uid }}__score-brand hc-{{ uid }}__score-brand--trustpilot" src="{{ 'logo-trustpilot.svg' | asset_url }}" alt="" width="18" height="18" loading="lazy">
            <span class="hc-{{ uid }}__score-text"><strong>{{ s.tp_score }}</strong> op Trustpilot</span>
          {%- endcapture -%}
          {%- if s.tp_url != blank -%}
            <a class="hc-{{ uid }}__score" href="{{ s.tp_url }}" target="_blank" rel="noopener">{{ tp_inner }}</a>
          {%- else -%}
            <span class="hc-{{ uid }}__score">{{ tp_inner }}</span>
          {%- endif -%}
        {%- endif -%}
        {%- if s.g_score != blank -%}
          {%- capture g_inner -%}
            <img class="hc-{{ uid }}__score-brand hc-{{ uid }}__score-brand--google" src="{{ 'logo-google.svg' | asset_url }}" alt="Google" width="18" height="18" loading="lazy">
            <span class="hc-{{ uid }}__score-text"><strong>{{ s.g_score }}</strong> op Google</span>
          {%- endcapture -%}
          {%- if s.g_url != blank -%}
            <a class="hc-{{ uid }}__score" href="{{ s.g_url }}" target="_blank" rel="noopener">{{ g_inner }}</a>
          {%- else -%}
            <span class="hc-{{ uid }}__score">{{ g_inner }}</span>
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="hc-{{ uid }}__usps" data-rise="6">
        {%- for block in section.blocks -%}
          <li class="hc-{{ uid }}__usp" {{ block.shopify_attributes }}>
            {%- case block.settings.icon -%}
              {%- when 'box' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 8h16v12H4z"/><path d="M4 8l2-4h12l2 4M12 8v12"/></svg>
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 16V6h11v10M14 9h4l3 3v4h-7"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
              {%- when 'lock' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="5" y="10" width="14" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
              {%- when 'return' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 10h11a5 5 0 0 1 0 10H9"/><path d="m8 6-4 4 4 4"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m4 12 5 5L20 7"/></svg>
            {%- endcase -%}
            <span>{{ block.settings.text }}</span>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

<script>
  // ponytail: view-transitions slikt fragment-navigatie in; scroll ankerlinks zelf
  document.addEventListener('click', function (e) {
    var a = e.target.closest('a[href^="#"]');
    if (!a || !a.hash || a.hash === '#') return;
    var t = document.getElementById(a.hash.slice(1));
    if (!t) return;
    e.preventDefault();
    // expliciet 'instant': de CSS scroll-behavior:smooth van .page-wrapper no-opt bij programmatisch scrollen
    t.scrollIntoView({ behavior: 'instant', block: 'start' });
    // nieuwe positie in history.state, anders herstelt scroll-container.js naar de oude
    // zelfde container-keuze als scroll-container.js: ≥990px scrollt .page-wrapper, daaronder het document
    var sc = (matchMedia('(min-width: 990px)').matches && document.querySelector('.page-wrapper')) || document.scrollingElement;
    history.replaceState({ scrollTop: sc.scrollTop }, '', a.hash);
  });
</script>

{% schema %}
{
  "name": "Hero — gecentreerd",
  "tag": "section",
  "class": "hero-centered-section",
  "settings": [
    { "type": "header", "content": "Tekst" },
    { "type": "text", "id": "eyebrow", "label": "Bovenkopje", "default": "Discreet plezier, thuisbezorgd" },
    { "type": "textarea", "id": "heading", "label": "Kop", "info": "Enter = nieuwe regel. Zo bepaal je zelf de regelval.", "default": "Wat je thuis doet\nblijft thuis" },
    { "type": "text", "id": "emphasis", "label": "Accentwoord", "info": "Dit stukje uit de kop wordt cursief in de accentkleur. Moet exact zo in de kop staan en mag niet over twee regels lopen.", "default": "blijft thuis" },
    { "type": "richtext", "id": "subtext", "label": "Subtekst", "default": "<p>Zorgvuldig geselecteerd. Neutraal verpakt. Niemand hoeft het te weten.</p>" },
    { "type": "text", "id": "cta_label", "label": "Knoptekst", "default": "Ontdek de collectie" },
    { "type": "url", "id": "cta_link", "label": "Knoplink" },
    { "type": "text", "id": "link_label", "label": "Secundaire link", "default": "Bestsellers" },
    { "type": "url", "id": "link_url", "label": "Link secundaire link" },

    { "type": "header", "content": "Trustpilot" },
    { "type": "text", "id": "tp_score", "label": "Score", "default": "4,7" },
    { "type": "text", "id": "tp_count", "label": "Aantal", "default": "312 reviews" },
    { "type": "url", "id": "tp_url", "label": "Link naar je Trustpilot-pagina" },

    { "type": "header", "content": "Google" },
    { "type": "text", "id": "g_score", "label": "Score", "default": "4,8" },
    { "type": "text", "id": "g_count", "label": "Aantal", "default": "184 reviews" },
    { "type": "url", "id": "g_url", "label": "Link naar je Google-pagina" },

    { "type": "header", "content": "Achtergrond" },
    { "type": "image_picker", "id": "image", "label": "Afbeelding" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "label": "Donkerte over de foto", "default": 55 },
    { "type": "range", "id": "height", "min": 320, "max": 900, "step": 20, "unit": "px", "label": "Hoogte", "default": 520 },

    { "type": "header", "content": "Typografie" },
    { "type": "font_picker", "id": "font_display", "label": "Kop", "default": "playfair_display_n4" },
    { "type": "font_picker", "id": "font_body", "label": "Tekst", "default": "assistant_n4" },
    { "type": "range", "id": "heading_size", "min": 28, "max": 88, "step": 2, "unit": "px", "label": "Grootte kop", "default": 58 },
    { "type": "range", "id": "sub_size", "min": 13, "max": 22, "step": 1, "unit": "px", "label": "Grootte subtekst", "default": 17 },

    { "type": "header", "content": "Kleuren" },
    { "type": "color", "id": "color_bg", "label": "Achtergrond", "default": "#0b0b0b" },
    { "type": "color", "id": "color_accent", "label": "Accent (goud)", "default": "#c9a063" },
    { "type": "color", "id": "color_text", "label": "Teksten", "default": "#e6e3dd" },
    { "type": "color", "id": "color_cta_text", "label": "Knop tekst", "default": "#1a1a1a" }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "Trust-punt",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "text", "label": "Tekst", "default": "Neutrale verpakking" },
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "check",
          "options": [
            { "value": "check", "label": "Vinkje" },
            { "value": "box", "label": "Doos" },
            { "value": "truck", "label": "Bezorging" },
            { "value": "lock", "label": "Slot" },
            { "value": "return", "label": "Retour" }
          ]
        }
      ]
    }
  ],
  "presets": [
    { "name": "Hero — gecentreerd" }
  ]
}
{% endschema %}