    "faq_pdp": {
      "type": "faq",
      "blocks": {
        "faq_discretie": {
          "type": "faq",
          "settings": {
            "question": "Hoe discreet is de verzending echt?",
            "answer": "<p>Volledig. Je bestelling komt in een effen doos zonder logo, tekst of afbeelding — ook het verzendlabel verraadt niets over de inhoud.</p>"
          }
        },
        "faq_bank": {
          "type": "faq",
          "settings": {
            "question": "Wat staat er op mijn bankafschrift?",
            "answer": "<p>Een neutrale bedrijfsnaam, niet onze winkelnaam. Niemand die je afschrift ziet weet waar je besteld hebt.</p>"
          }
        },
        "faq_levering": {
          "type": "faq",
          "settings": {
            "question": "Hoe snel heb ik mijn bestelling in huis?",
            "answer": "<p>Voor 22:00 besteld is morgen in huis. Liever niet thuis ontvangen? Kies bij het afrekenen een afhaalpunt bij jou in de buurt.</p>"
          }
        },
        "faq_retour": {
          "type": "faq",
          "settings": {
            "question": "Kan ik een product ruilen of retourneren?",
            "answer": "<p>Ongeopende producten in verzegelde verpakking kun je binnen 14 dagen retourneren. Om hygiënische redenen kunnen geopende producten helaas niet retour — twijfel je over een keuze, stel ons gerust eerst je vraag.</p>"
          }
        },
        "faq_beginnen": {
          "type": "faq",
          "settings": {
            "question": "Hoe gaan jullie om met mijn gegevens?",
            "answer": "<p>Je gegevens worden nooit gedeeld voor marketing van derden. Je ontvangt alleen e-mails over je bestelling, tenzij je jezelf aanmeldt voor meer.</p>"
          }
        }
      },
